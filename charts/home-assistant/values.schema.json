{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "registry":    { "type": "string" },
            "repository":  { "type": "string" },
            "tag":         { "type": "string" },
            "digest":      { "type": "string" },
            "pullPolicy":  { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
            "pullSecrets": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "nameOverride":     { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "replicaCount":     { "type": "integer", "minimum": 1 },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create":      { "type": "boolean" },
        "name":        { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "initContainers": { "type": "array" },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":      { "type": "string" },
          "value":     { "type": "string" },
          "valueFrom": { "type": "object" }
        }
      }
    },
    "secretVolumeMounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["secretName"],
        "additionalProperties": false,
        "properties": {
          "secretName": { "type": "string" },
          "mountPath":  { "type": "string", "pattern": "^[^/]" },
          "name":       { "type": "string" }
        }
      }
    },
    "extraVolumes":      { "type": "array" },
    "extraVolumeMounts": { "type": "array" },
    "startupProbe": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "livenessProbe": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "readinessProbe": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "memory": { "type": "string" },
            "cpu":    { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "memory": { "type": "string" },
            "cpu":    { "type": "string" }
          }
        }
      }
    },
    "pod": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "annotations":  { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations":  { "type": "array" },
        "affinity":     { "type": "object" },
        "hostNetwork":  { "type": "boolean" }
      }
    },
    "networking": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service": {
          "type": "object",
          "required": ["app"],
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean" },
              "type": {
                "type": "string",
                "enum": ["ClusterIP", "LoadBalancer", "NodePort"]
              },
              "ports": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["port", "protocol"],
                  "properties": {
                    "port":     { "type": "integer" },
                    "protocol": { "type": "string", "enum": ["TCP", "UDP"] },
                    "enabled":  { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gateway": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":    { "type": "boolean" },
            "parentRefs": { "type": "array", "items": { "type": "object" } },
            "hostnames":  { "type": "array", "items": { "type": "string" } }
          }
        },
        "traefik": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":     { "type": "boolean" },
            "entryPoints": { "type": "array", "items": { "type": "string" } },
            "hostnames":   { "type": "array", "items": { "type": "string" } },
            "middlewares": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "additionalProperties": false,
                "properties": {
                  "name":      { "type": "string" },
                  "namespace": { "type": "string" }
                }
              }
            },
            "tls": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled":      { "type": "boolean" },
                "secretName":   { "type": "string" },
                "certResolver": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":       { "type": "boolean" },
        "storageClass":  { "type": "string" },
        "accessModes":   { "type": "array", "items": { "type": "string" } },
        "size":          { "type": "string" },
        "annotations":   { "type": "object" },
        "labels":        { "type": "object" },
        "existingClaim":  { "type": "string" },
        "existingVolume": { "type": "string" }
      }
    },
    "monitor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metric": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":       { "type": "boolean" },
            "path":          { "type": "string" },
            "port":          { "type": "string" },
            "interval":      { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "labels":        { "type": "object" }
          }
        }
      }
    },
    "homeAssistant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initContainer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "registry":   { "type": "string" },
                "repository": { "type": "string" },
                "tag":        { "type": "string" },
                "digest":     { "type": "string" },
                "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
              }
            },
            "tasks": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "setupHACS": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "version": { "type": "string" }
                  }
                },
                "setupSecretsYaml": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled":    { "type": "boolean" },
                    "secretName": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":           { "type": "boolean" },
            "existingConfigMap": { "type": "string" },
            "checkConfig": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        },
        "packages": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":           { "type": "boolean" },
            "existingConfigMap": { "type": "string" }
          }
        },
        "themes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":           { "type": "boolean" },
            "existingConfigMap": { "type": "string" }
          }
        }
      }
    }
  }
}
